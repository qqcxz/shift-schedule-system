.login-page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
  background:
    radial-gradient(circle at top left, rgba(37, 99, 235, 0.16), transparent 30%),
    radial-gradient(circle at bottom right, rgba(16, 185, 129, 0.14), transparent 28%),
    #eef2ff;
  box-sizing: border-box;
}

.login-card {
  margin-top: 80rpx;
}

.brand {
  display: flex;
  gap: 20rpx;
  align-items: center;
  margin-bottom: 36rpx;
}

.logo {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 40rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #2563eb, #10b981);
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.field {
  margin-bottom: 24rpx;
}

.label {
  margin-bottom: 12rpx;
  color: #374151;
  font-weight: 600;
}

.input {
  background: #f9fafb;
  border: 1px solid #e5e7eb;
  border-radius: 16rpx;
  padding: 20rpx 22rpx;
}

.submit {
  margin-top: 12rpx;
}

.tips {
  margin-top: 24rpx;
  line-height: 1.6;
  font-size: 24rpx;
}

.api-box {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1px dashed #e5e7eb;
}

.tiny {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.5;
}

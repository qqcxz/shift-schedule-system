.toolbar {
  margin-bottom: 20rpx;
}

.month {
  font-size: 32rpx;
  font-weight: 700;
  min-width: 160rpx;
  text-align: center;
}

.tip {
  margin-top: 16rpx;
  font-size: 24rpx;
}

.user-bar {
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1px solid #f3f4f6;
}

.strong {
  font-weight: 700;
  margin-right: 12rpx;
}

.link {
  color: #2563eb;
}

.legend {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.table-scroll {
  width: 100%;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.04);
}

.table {
  min-width: 100%;
  display: inline-block;
}

.tr {
  display: flex;
  border-bottom: 1px solid #eef2f7;
}

.tr.head {
  position: sticky;
  top: 0;
  z-index: 2;
  background: #f8fafc;
}

.th,
.td {
  flex: 0 0 96rpx;
  width: 96rpx;
  min-height: 96rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-right: 1px solid #eef2f7;
  box-sizing: border-box;
  padding: 8rpx 4rpx;
  text-align: center;
}

.sticky {
  position: sticky;
  left: 0;
  z-index: 3;
  background: #fff;
  flex-basis: 140rpx !important;
  width: 140rpx !important;
  align-items: flex-start;
  padding-left: 16rpx;
}

.tr.head .sticky {
  background: #f8fafc;
  z-index: 4;
}

.weekend {
  background: #fcfcfd;
}

.editable:active {
  background: #eff6ff;
}

.user-name {
  font-weight: 600;
  font-size: 24rpx;
}

.weekday {
  color: #9ca3af;
  font-size: 20rpx;
}

.manage-entry {
  margin-bottom: 20rpx;
}

.tiny {
  font-size: 22rpx;
}


.mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.45);
  display: flex;
  align-items: flex-end;
  z-index: 20;
}

.dialog {
  width: 100%;
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
  max-height: 85vh;
  overflow: auto;
}

.dialog-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.field {
  margin-bottom: 20rpx;
}

.label {
  margin-bottom: 10rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.input {
  background: #f9fafb;
  border: 1px solid #e5e7eb;
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
}

.actions {
  margin-top: 18rpx;
}

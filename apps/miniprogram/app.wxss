/**app.wxss**/
page {
  background: #f3f4f6;
  color: #111827;
  font-size: 28rpx;
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.04);
}

.muted {
  color: #9ca3af;
}

.row {
  display: flex;
  align-items: center;
}

.between {
  justify-content: space-between;
}

.gap {
  gap: 16rpx;
}

.btn-primary {
  background: #2563eb;
  color: #fff;
  border-radius: 16rpx;
}

.btn-ghost {
  background: #eff6ff;
  color: #2563eb;
  border-radius: 16rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.tag-info {
  background: #eff6ff;
  color: #2563eb;
}

.tag-success {
  background: #ecfdf5;
  color: #059669;
}

.tag-warning {
  background: #fff7ed;
  color: #d97706;
}

.tag-danger {
  background: #fef2f2;
  color: #dc2626;
}

.shift-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 72rpx;
  padding: 6rpx 12rpx;
  border-radius: 12rpx;
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
}

.empty {
  padding: 80rpx 24rpx;
  text-align: center;
  color: #9ca3af;
}
